# Required for LLM-powered features. Get one at https://cursor.com/dashboard/integrations
CURSOR_API_KEY=YOUR_CURSOR_API_KEY

# Optional: change the API port (default 5278).
# PORT=5278

# NOTE: Specialist identities, models, tone, and model parameters are
# configured from the UI (Specialists tab) and persisted in your browser's
# localStorage. There are no server-side model defaults to set here.
